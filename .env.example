# Copy this file to ".env" and fill in your Supabase connection string.
# The .env file is git-ignored, so your password is never committed.
#
# In Supabase: click "Connect" (top bar) -> choose "Session pooler" -> copy URI.
# The Session pooler (port 5432) works on all networks. Avoid the "Transaction
# pooler" (port 6543). Replace [YOUR-PASSWORD] with your database password.
#
# Easiest: just run setup_db.bat and paste the string when asked.
# If you leave this unset, the tool uses a local SQLite file instead.

SUPABASE_DB_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres
