# Copy this file to ".env" and fill in your Supabase connection string.
# The .env file is git-ignored, so your password is never committed.
#
# In Supabase: Project Settings -> Database -> Connection string -> "URI".
# Use the DIRECT connection (port 5432), not the transaction pooler (6543).
# Replace [YOUR-PASSWORD] with your database password.
#
# If you leave this unset, the tool uses a local SQLite file instead.

SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres
